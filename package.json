{
  "name": "WubiDictEditor",
  "version": "1.3.4",
  "private": true,
  "author": {
    "name": "KyleBing",
    "email": "kylebing@163.com"
  },
  "date": "2026-06-19",
  "dateInit": "2021-07-24",
  "description": "五笔码表管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32 --arch=x64",
    "make:linux": "electron-forge make --platform=linux --arch=x64",
    "pack:mac": "bash scripts/pack-mac.sh",
    "pack:mac:arm64": "bash scripts/pack-mac.sh arm64",
    "pack:mac:x64": "bash scripts/pack-mac.sh x64",
    "pack:mac:all": "bash scripts/pack-mac.sh arm64 && bash scripts/pack-mac.sh x64",
    "pack:deepin": "bash scripts/pack-debian.sh",
    "pack:debian": "bash scripts/pack-debian.sh",
    "pack:manjaro": "bash scripts/pack-manjaro.sh",
    "pack:linux": "bash scripts/install-linux.sh",
    "install:electron": "node node_modules/electron/install.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "axios": "^1.2.1",
    "electron-squirrel-startup": "^1.0.0",
    "plist": "^3.0.4",
    "vue": "^2.6.14",
    "vue-virtual-scroller": "^1.0.10"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "dotenv": "^16.4.7",
    "electron": "^28.3.3"
  }
}
